  "engines": {
    "node": "^20.19.0 || >=22.0.0"
  },
  "homepage": "https://github.com/Hyk260/PureChat",
  "bugs": {
    "url": "https://github.com/Hyk260/PureChat/issues"
  },
  "keywords": [
    "ai",
    "im",
    "vue",
    "vue3",
    "openai",
    "deepseek",
    "chatgpt",
    "vite",
    "markdown",
    "unocss",
    "wangeditor",
    "element-plus",
    "electron",
    "typescript"
  ],
  "repository": {
    "url": "https://github.com/Hyk260/PureChat.git"
  },
  "license": "MIT",
  "docs": "https://docs.purechat.cn",
  "packageManager": "pnpm@9.7.1",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "chokidar": "^4.0.3",
        "nanoid": "^5.0.0"
      }
    },
    "packageExtensions": {
      "nunjucks@3.2.4": {
        "peerDependencies": {
          "chokidar": "^3.3.0 || ^4.0.0"
        }
      }
    }
  },
  "lint-staged": {
    "*.{vue,js,ts,cjs,mjs,cts,mts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css,scss,html}": [
      "prettier --write"
    ]
  }
}
