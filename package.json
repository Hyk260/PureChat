{
  "name": "pure-chat",
  "version": "1.0.0",
  "description": "PureChat - A chat application built with Vue and Vite",
  "type": "module",
  "author": {
    "name": "Hyk260",
    "email": "2607881950@qq.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:debug": "vite build --debug",
    "build:github": "cross-env VITE_BASE_URL=/PureChat/ vite build",
    "build:cdn": "cross-env VITE_CDN=Y vite build",
    "build:preview": "vite build && vite preview",
    "analyze": "rimraf dist && vite build",
    "preview": "vite preview",
    "preview:github": "cross-env VITE_BASE_URL=/PureChat/ vite preview",
    "clean": "rimraf dist",
    "lint:vue": "eslint . --ext .vue --fix",
    "lint": "eslint . --ext .vue,.js,.ts --fix",
    "lint:check": "eslint . --ext .vue,.js,.ts",
    "type:check": "vue-tsc --noEmit",
    "type:watch": "vue-tsc --noEmit --watch",
    "check": "node scripts/check-all.js",
    "skills:sync": "tsx scripts/skills-sync.ts",
    "skills:check": "tsx scripts/skills-check.ts"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.0.10",
    "@guolao/vue-monaco-editor": "^1.5.5",
    "@iconify/vue": "^4.3.0",
    "@pure/const": "workspace:*",
    "@pure/database": "workspace:*",
    "@pure/icons": "workspace:*",
    "@pure/model-runtime": "workspace:*",
    "@pure/prompts": "workspace:*",
    "@pure/ui": "workspace:*",
    "@pure/utils": "workspace:*",
    "@shikijs/core": "^3.12.0",
