    "pinyin-pro": "^3.18.5",
    "qrcode": "^1.5.3",
    "shiki": "^3.13.0",
    "snabbdom": "^3.5.1",
    "type-fest": "^5.0.1",
    "ua-parser-js": "^1.0.41",
    "uuid": "^11.0.3",
    "vanilla-lazyload": "^19.1.3",
